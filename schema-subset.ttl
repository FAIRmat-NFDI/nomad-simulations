    nomad:propertyKind "quantity" .

<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.model_method.SlaterKosterBond/orbital_2> a owl:ObjectProperty ;
    rdfs:label "orbital_2" ;
    rdfs:comment "Reference to the second `ElectronicState` section." ;
    rdfs:domain <https://fairmat-nfdi.github.io/nomad-simulations/rdf/section/nomad_simulations.schema_packages.model_method.SlaterKosterBond> ;
