    rdfs:comment "Contains reference to DFT outputs." ;
    rdfs:subClassOf <https://fairmat-nfdi.github.io/nomad-simulations/rdf/section/nomad.datamodel.data.ArchiveSection>,
        <https://fairmat-nfdi.github.io/nomad-simulations/rdf/section/nomad_simulations.schema_packages.workflow.general.SimulationWorkflowResults>,
        <https://fairmat-nfdi.github.io/nomad-simulations/rdf/section/nomad_simulations.schema_packages.workflow.general.WorkflowTime> ;
