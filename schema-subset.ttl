that can also store approximation-specific parameters, such as scaling
factors and explicitly corrected orbitals.""" ;
    rdfs:subClassOf <https://fairmat-nfdi.github.io/nomad-simulations/rdf/section/nomad.datamodel.data.ArchiveSection>,
        <https://fairmat-nfdi.github.io/nomad-simulations/rdf/section/nomad_simulations.schema_packages.model_method.BaseModelMethod> ;
    nomad:pythonClass "nomad_simulations.schema_packages.model_method.SelfInteractionCorrection" ;
    nomad:pythonModule "nomad_simulations.schema_packages.model_method" .

<https://fairmat-nfdi.github.io/nomad-simulations/rdf/section/nomad_simulations.schema_packages.model_method.SemiEmpirical> a owl:Class ;
    rdfs:label "SemiEmpirical" ;
    rdfs:comment "A base section used to define semi-empirical quantum chemistry methods such as MINDO, MNDO, AM1, PM3, PM6, PM7, and SAM1." ;
    rdfs:subClassOf <https://fairmat-nfdi.github.io/nomad-simulations/rdf/section/nomad.datamodel.data.ArchiveSection>,
        <https://fairmat-nfdi.github.io/nomad-simulations/rdf/section/nomad_simulations.schema_packages.model_method.BaseModelMethod>,
        <https://fairmat-nfdi.github.io/nomad-simulations/rdf/section/nomad_simulations.schema_packages.model_method.ModelMethod>,
        <https://fairmat-nfdi.github.io/nomad-simulations/rdf/section/nomad_simulations.schema_packages.model_method.ModelMethodElectronic> ;
    nomad:pythonClass "nomad_simulations.schema_packages.model_method.SemiEmpirical" ;
    nomad:pythonModule "nomad_simulations.schema_packages.model_method" .

<https://fairmat-nfdi.github.io/nomad-simulations/rdf/section/nomad_simulations.schema_packages.model_system.AlternativeRepresentation> a owl:Class ;
    rdfs:label "AlternativeRepresentation" ;
    rdfs:comment "A representation relative to another, reference representation, typically the original computed system." ;
    rdfs:subClassOf <https://fairmat-nfdi.github.io/nomad-simulations/rdf/section/nomad.datamodel.data.ArchiveSection>,
        <https://fairmat-nfdi.github.io/nomad-simulations/rdf/section/nomad_simulations.schema_packages.model_system.Representation> ;
    nomad:pythonClass "nomad_simulations.schema_packages.model_system.AlternativeRepresentation" ;
    nomad:pythonModule "nomad_simulations.schema_packages.model_system" .

<https://fairmat-nfdi.github.io/nomad-simulations/rdf/section/nomad_simulations.schema_packages.model_system.GlobalSymmetry> a owl:Class ;
    rdfs:label "GlobalSymmetry" ;
    rdfs:comment "A base section specifying the global symmetry of the corresponding `ModelSystem` at large, which can be used for categorization and lookup. It does not define local, site-specific symmetry." ;
    rdfs:subClassOf <https://fairmat-nfdi.github.io/nomad-simulations/rdf/section/nomad.datamodel.data.ArchiveSection> ;
    nomad:pythonClass "nomad_simulations.schema_packages.model_system.GlobalSymmetry" ;
