<https://fairmat-nfdi.github.io/nomad-simulations/rdf/section/nomad_simulations.schema_packages.properties.thermodynamics.Enthalpy> a owl:Class ;
    rdfs:label "Enthalpy" ;
    rdfs:comment "The total heat content of a system, defined as 'InternalEnergy' + 'Pressure' * 'Volume'." ;
    rdfs:subClassOf <https://fairmat-nfdi.github.io/nomad-simulations/rdf/section/nomad.datamodel.data.ArchiveSection>,
