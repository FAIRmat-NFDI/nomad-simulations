    rdfs:label "core_hole_ref" ;
    rdfs:comment "Reference to the `CoreHole` section that contains the information of the edge of the excited core-hole." ;
    rdfs:domain <https://fairmat-nfdi.github.io/nomad-simulations/rdf/section/nomad_simulations.schema_packages.model_method.CoreHoleSpectra> ;
    rdfs:range <https://fairmat-nfdi.github.io/nomad-simulations/rdf/section/nomad_simulations.schema_packages.atoms_state.CoreHole> ;
    nomad:propertyKind "quantity" .

