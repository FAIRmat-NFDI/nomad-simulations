<https://fairmat-nfdi.github.io/nomad-simulations/rdf/section/nomad_simulations.schema_packages.force_field.PolynomialPotential> a owl:Class ;
    rdfs:label "PolynomialPotential" ;
    rdfs:comment """Abstract class for potentials with polynomial form: $V(x) = [\\left k_1 (x - x_0) + k_2 (x - x_0)^2 + x_3 (x - x_0)^3 + \\dots + C$,
where $\\{x_1, x_2, x_3 \\dots}$ are the `force_constants` for each term in the polynomial
expression and $x_0$ is the `equilibrium_value` of $x$. $C$ is an arbitrary constant (not stored).
This class is intended to be used with another class specifying the potential type, e.g., BondPotential, AnglePotential, etc.""" ;
    rdfs:subClassOf <https://fairmat-nfdi.github.io/nomad-simulations/rdf/section/nomad.datamodel.data.ArchiveSection>,
        <https://fairmat-nfdi.github.io/nomad-simulations/rdf/section/nomad_simulations.schema_packages.force_field.Potential>,
