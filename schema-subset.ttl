<https://fairmat-nfdi.github.io/nomad-simulations/rdf/section/nomad_simulations.schema_packages.properties.thermodynamics.Entropy> a owl:Class ;
    rdfs:label "Entropy" ;
    rdfs:comment """A measure of the disorder or randomness in a system. From a thermodynamic perspective, `Entropy` is a measure of the system's energy
dispersal at a specific temperature, and can be interpreted as the unavailability of
a system's thermal energy for conversion into mechanical work. For a reversible
process, the change in `Entropy` is given mathematically by an integral over the
infinitesimal `Heat` (i.e., thermal energy transfered into the system) divided by the
`Temperature`.

From a statistical mechanics viewpoint, entropy quantifies the number of microscopic
configurations (microstates) that correspond to a thermodynamic system's macroscopic
state, as given by the Boltzmann equation for entropy.""" ;
    rdfs:subClassOf <https://fairmat-nfdi.github.io/nomad-simulations/rdf/section/nomad.datamodel.data.ArchiveSection>,
        <https://fairmat-nfdi.github.io/nomad-simulations/rdf/section/nomad.datamodel.metainfo.plot.PlotSection>,
        <https://fairmat-nfdi.github.io/nomad-simulations/rdf/section/nomad_simulations.schema_packages.physical_property.PhysicalProperty> ;
    nomad:pythonClass "nomad_simulations.schema_packages.properties.thermodynamics.Entropy" ;
    nomad:pythonModule "nomad_simulations.schema_packages.properties.thermodynamics" .

<https://fairmat-nfdi.github.io/nomad-simulations/rdf/section/nomad_simulations.schema_packages.properties.thermodynamics.GibbsFreeEnergy> a owl:Class ;
    rdfs:label "GibbsFreeEnergy" ;
    rdfs:comment "The energy available to do work in a system at constant temperature and pressure, given by `Enthalpy` - `Temperature` * `Entropy`." ;
    rdfs:subClassOf <https://fairmat-nfdi.github.io/nomad-simulations/rdf/section/nomad.datamodel.data.ArchiveSection>,
