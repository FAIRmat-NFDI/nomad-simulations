<https://fairmat-nfdi.github.io/nomad-simulations/rdf/subsection/nomad_simulations.schema_packages.model_system.ModelSystem/particle_states> a owl:ObjectProperty ;
    rdfs:label "particle_states" ;
    rdfs:comment """Particle state of each of the particles conforming the ModelSystem.
This is a list of `n_particles` elements and the order matches that of `positions`.

    Example
    -------
    A water molecule (H₂O):

        positions       : [[…], […], […]]      # 3 atoms
        particle_states :
            [0] AtomsState(H)
            [1] AtomsState(H)
            [2] AtomsState(O)""" ;
    rdfs:domain <https://fairmat-nfdi.github.io/nomad-simulations/rdf/section/nomad_simulations.schema_packages.model_system.ModelSystem> ;
    rdfs:range <https://fairmat-nfdi.github.io/nomad-simulations/rdf/section/nomad_simulations.schema_packages.atoms_state.ParticleState> ;
