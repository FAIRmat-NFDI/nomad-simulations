        <https://fairmat-nfdi.github.io/nomad-simulations/rdf/section/nomad_simulations.schema_packages.numerical_settings.Mesh> ;
    nomad:pythonClass "nomad_simulations.schema_packages.basis_set.MuffinTinRegion" ;
    nomad:pythonModule "nomad_simulations.schema_packages.basis_set" .

<https://fairmat-nfdi.github.io/nomad-simulations/rdf/section/nomad_simulations.schema_packages.basis_set.PlaneWaveBasisSet> a owl:Class ;
    rdfs:label "PlaneWaveBasisSet" ;
    rdfs:comment """Basis set over a reciprocal mesh, where each point $k_n$ represents a planar-wave basis function $rac{1}{\\sqrt{\\omega}} e^{i k_n r}$. Typically the grid itself is cartesian with only points within a designated sphere considered.
The cutoff radius may be defined by a reciprocal length, or more commonly, the equivalent kinetic energy for a free particle.

* D. J. Singh and L. Nordström, "Why Planewaves" in Planewaves, pseudopotentials, and the LAPW method, 2nd ed. New York, NY: Springer, 2006, pp. 24-26.""" ;
    rdfs:subClassOf <https://fairmat-nfdi.github.io/nomad-simulations/rdf/section/nomad.datamodel.data.ArchiveSection>,
        <https://fairmat-nfdi.github.io/nomad-simulations/rdf/section/nomad_simulations.schema_packages.basis_set.BasisSetComponent>,
