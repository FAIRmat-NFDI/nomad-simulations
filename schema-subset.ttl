    rdfs:label "convergence_targets" ;
    rdfs:domain <https://fairmat-nfdi.github.io/nomad-simulations/rdf/section/nomad_simulations.schema_packages.workflow.geometry_optimization.GeometryOptimizationMethod> ;
    rdfs:range <https://fairmat-nfdi.github.io/nomad-simulations/rdf/section/nomad_simulations.schema_packages.workflow.general.WorkflowConvergenceTarget> ;
