<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.properties.band_gap.ElectronicBandGap/momentum_transfer> nomad:propertyKind "quantity" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.properties.band_gap.ElectronicBandGap/momentum_transfer> nomad:shape "[2, 3]"^^xsd:string .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.properties.band_gap.ElectronicBandGap/spin_channel> rdf:type owl:DatatypeProperty .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.properties.band_gap.ElectronicBandGap/spin_channel> rdfs:comment "\n        Spin channel of the corresponding electronic band gap. It can take values of 0 or 1.\n        " .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.properties.band_gap.ElectronicBandGap/spin_channel> rdfs:domain <https://fairmat-nfdi.github.io/nomad-simulations/rdf/section/nomad_simulations.schema_packages.properties.band_gap.ElectronicBandGap> .
