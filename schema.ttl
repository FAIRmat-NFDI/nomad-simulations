<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.workflow.molecular_dynamics.BarostatParameters/pressure_update_delta> nomad:propertyKind "quantity" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.workflow.molecular_dynamics.BarostatParameters/pressure_update_delta> nomad:shape "[]"^^xsd:string .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.workflow.molecular_dynamics.BarostatParameters/pressure_update_factor> rdf:type owl:DatatypeProperty .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.workflow.molecular_dynamics.BarostatParameters/pressure_update_factor> rdfs:comment "\n        Factor to be multiplied to the current reference_pressure at a frequency of pressure_update_frequency when pressure_profile is exponential.\n        The reference pressure is then replaced by this new value until the next update.\n        " .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.workflow.molecular_dynamics.BarostatParameters/pressure_update_factor> rdfs:domain <https://fairmat-nfdi.github.io/nomad-simulations/rdf/section/nomad_simulations.schema_packages.workflow.molecular_dynamics.BarostatParameters> .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.workflow.molecular_dynamics.BarostatParameters/pressure_update_factor> rdfs:label "pressure_update_factor" .
