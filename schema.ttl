<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.PPCutoff/value> rdfs:label "value" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.PPCutoff/value> rdfs:range xsd:double .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.PPCutoff/value> nomad:propertyKind "quantity" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.PPCutoff/value> nomad:unit "'joule'"^^xsd:string .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.Pseudopotential/is_gw_optimized> rdf:type owl:DatatypeProperty .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.Pseudopotential/is_gw_optimized> rdfs:comment "\n        Whether this pseudopotential was optimized for GW/excited-state calculations.\n        GW-optimized pseudopotentials are validated for scattering properties far above\n        the Fermi level and typically include more semi-core states. They remain valid\n        for standard DFT calculations but are computationally more expensive.\n        " .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.Pseudopotential/is_gw_optimized> rdfs:domain <https://fairmat-nfdi.github.io/nomad-simulations/rdf/section/nomad_simulations.schema_packages.numerical_settings.Pseudopotential> .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.Pseudopotential/is_gw_optimized> rdfs:label "is_gw_optimized" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.Pseudopotential/is_gw_optimized> rdfs:range xsd:boolean .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.Pseudopotential/is_gw_optimized> nomad:propertyKind "quantity" .
