<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.model_system.Representation/coordinates_system> rdf:type owl:DatatypeProperty .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.model_system.Representation/coordinates_system> rdfs:comment "\n        Coordinate system convention used to interpret the positions quantity. Defaults to 'cartesian',\n        which is used in practice for almost all simulation data.\n\n        For 'cartesian', positions and lattice_vectors are expressed in an implicit Cartesian frame (x, y, z).\n\n        | name       | description | dimensionalities | coordinates |\n        |------------|-------------|------------------|-------------|\n        | cartesian  | implicit Cartesian coordinate system | 1, 2, 3 | x, y, z |\n        | cylindrical| cylindrical symmetry | 3 | r, theta, z |\n        | spherical  | spherical symmetry | 3 | r, theta, phi |\n        | ellipsoidal| spherically elongated system | 3 | r, theta, phi |\n        | polar      | spherical symmetry | 2 | r, theta |\n        " .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.model_system.Representation/coordinates_system> rdfs:domain <https://fairmat-nfdi.github.io/nomad-simulations/rdf/section/nomad_simulations.schema_packages.model_system.Representation> .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.model_system.Representation/coordinates_system> rdfs:label "coordinates_system" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.model_system.Representation/coordinates_system> rdfs:range xsd:string .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.model_system.Representation/coordinates_system> nomad:enumValue "cartesian" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.model_system.Representation/coordinates_system> nomad:enumValue "cylindrical" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.model_system.Representation/coordinates_system> nomad:enumValue "ellipsoidal" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.model_system.Representation/coordinates_system> nomad:enumValue "polar" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.model_system.Representation/coordinates_system> nomad:enumValue "spherical" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.model_system.Representation/coordinates_system> nomad:propertyKind "quantity" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.model_system.Representation/fractional_coordinates> rdf:type owl:DatatypeProperty .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.model_system.Representation/fractional_coordinates> rdfs:comment "\n            Fractional coordinates of all atoms in the system with respect to the lattice vectors.\n            Values typically range from 0 to 1 within the unit cell, though atoms may lie outside\n            this range in non-periodic directions or due to wrapping conventions.\n        " .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.model_system.Representation/fractional_coordinates> rdfs:domain <https://fairmat-nfdi.github.io/nomad-simulations/rdf/section/nomad_simulations.schema_packages.model_system.Representation> .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.model_system.Representation/fractional_coordinates> rdfs:label "fractional_coordinates" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.model_system.Representation/fractional_coordinates> rdfs:range xsd:double .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.model_system.Representation/fractional_coordinates> nomad:propertyKind "quantity" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.model_system.Representation/fractional_coordinates> nomad:shape "['*', 3]"^^xsd:string .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.model_system.Representation/lattice_vectors> rdf:type owl:DatatypeProperty .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.model_system.Representation/lattice_vectors> rdfs:comment "\n        Lattice vectors of the simulated cell, stored as a 3x3 matrix where each row is a lattice vector.\n        The first index runs over each lattice vector (a, b, c). The second index runs over the\n        implicit Cartesian coordinate system (x, y, z), the same frame used for positions.\n        " .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.model_system.Representation/lattice_vectors> rdfs:domain <https://fairmat-nfdi.github.io/nomad-simulations/rdf/section/nomad_simulations.schema_packages.model_system.Representation> .
