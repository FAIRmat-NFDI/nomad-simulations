<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.MultireferencePTSettings/contraction_type> nomad:enumValue "partially_contracted" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.MultireferencePTSettings/contraction_type> nomad:enumValue "strongly_contracted" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.MultireferencePTSettings/contraction_type> nomad:enumValue "uncontracted" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.MultireferencePTSettings/contraction_type> nomad:propertyKind "quantity" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.MultireferencePTSettings/imaginary_level_shift> rdf:type owl:DatatypeProperty .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.MultireferencePTSettings/imaginary_level_shift> rdfs:comment "\n        Imaginary level shift used as an alternative intruder-state stabilizer.\n        Typically a small positive value (e.g., 0.1 Ha).\n        " .
