<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.workflow.molecular_dynamics.ThermostatParameters/temperature_update_factor> nomad:shape "[]"^^xsd:string .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.workflow.molecular_dynamics.ThermostatParameters/temperature_update_frequency> rdf:type owl:DatatypeProperty .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.workflow.molecular_dynamics.ThermostatParameters/temperature_update_frequency> rdfs:comment "\n        Number of simulation steps between changing the target temperature.\n        " .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.workflow.molecular_dynamics.ThermostatParameters/temperature_update_frequency> rdfs:domain <https://fairmat-nfdi.github.io/nomad-simulations/rdf/section/nomad_simulations.schema_packages.workflow.molecular_dynamics.ThermostatParameters> .
