<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.basis_set.APWOrbital/type> nomad:enumValue "lapw" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.basis_set.APWOrbital/type> nomad:enumValue "slapw" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.basis_set.APWOrbital/type> nomad:propertyKind "quantity" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.basis_set.APWPlaneWaveBasisSet/cutoff_fractional> rdf:type owl:DatatypeProperty .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.basis_set.APWPlaneWaveBasisSet/cutoff_fractional> rdfs:comment "\n        The spherical cutoff parameter for the interstitial plane waves in the APW family.\n        This cutoff has no units, referring to the product of the smallest muffin-tin radius\n        and the length of the cutoff reciprocal vector ($r_{MT} * |K_{cut}|$).\n        " .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.basis_set.APWPlaneWaveBasisSet/cutoff_fractional> rdfs:domain <https://fairmat-nfdi.github.io/nomad-simulations/rdf/section/nomad_simulations.schema_packages.basis_set.APWPlaneWaveBasisSet> .
