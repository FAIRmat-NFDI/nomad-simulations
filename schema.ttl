<https://fairmat-nfdi.github.io/nomad-simulations/rdf/section/nomad_simulations.schema_packages.force_field.ParticleParameters> nomad:pythonClass "nomad_simulations.schema_packages.force_field.ParticleParameters" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/section/nomad_simulations.schema_packages.force_field.ParticleParameters> nomad:pythonModule "nomad_simulations.schema_packages.force_field" .
