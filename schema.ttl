<https://fairmat-nfdi.github.io/nomad-simulations/rdf/section/nomad_simulations.schema_packages.model_method.ModelMethodElectronic> nomad:pythonClass "nomad_simulations.schema_packages.model_method.ModelMethodElectronic" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/section/nomad_simulations.schema_packages.model_method.ModelMethodElectronic> nomad:pythonModule "nomad_simulations.schema_packages.model_method" .
