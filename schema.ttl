<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.Mesh/points> rdf:type owl:DatatypeProperty .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.Mesh/points> rdfs:comment "\n        List of all the points in the mesh.\n        " .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.Mesh/points> rdfs:domain <https://fairmat-nfdi.github.io/nomad-simulations/rdf/section/nomad_simulations.schema_packages.numerical_settings.Mesh> .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.Mesh/points> rdfs:label "points" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.Mesh/points> rdfs:range <https://fairmat-nfdi.github.io/nomad-simulations/rdf/datatype/complex128> .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.Mesh/points> nomad:propertyKind "quantity" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.Mesh/points> nomad:shape "['n_points', 'dimensionality']"^^xsd:string .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.Mesh/quadrature> rdf:type owl:DatatypeProperty .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.Mesh/quadrature> rdfs:comment "\n        Quadrature rule used for integration of the Mesh. This quantity is relevant for 1D meshes:\n\n        | Name      | Description                      |\n        | --------- | -------------------------------- |\n        | `'Gauss-Legendre'` | Quadrature rule for integration using Legendre polynomials |\n        | `'Gauss-Laguerre'` | Quadrature rule for integration using Laguerre polynomials |\n        | `'Clenshaw-Curtis'`  | Quadrature rule for integration using Chebyshev polynomials using discrete cosine transformations |\n        | `'Gauss-Hermite'`  | Quadrature rule for integration using Hermite polynomials |\n        " .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.Mesh/quadrature> rdfs:domain <https://fairmat-nfdi.github.io/nomad-simulations/rdf/section/nomad_simulations.schema_packages.numerical_settings.Mesh> .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.Mesh/quadrature> rdfs:label "quadrature" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.Mesh/quadrature> rdfs:range xsd:string .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.Mesh/quadrature> nomad:enumValue "Clenshaw-Curtis" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.Mesh/quadrature> nomad:enumValue "Gauss-Hermite" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.Mesh/quadrature> nomad:enumValue "Gauss-Laguerre" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.Mesh/quadrature> nomad:enumValue "Gauss-Legendre" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.Mesh/quadrature> nomad:enumValue "Newton-Cotes" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.Mesh/quadrature> nomad:propertyKind "quantity" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.Mesh/spacing> rdf:type owl:DatatypeProperty .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.Mesh/spacing> rdfs:comment "\n        Identifier for the spacing of the Mesh. Defaults to 'Equidistant' if not defined. It can take the values:\n\n        | Name      | Description                      |\n        | --------- | -------------------------------- |\n        | `'Equidistant'`  | Equidistant grid (also known as 'Newton-Cotes') |\n        | `'Logarithmic'`  | log distance grid |\n        | `'Tan'`  | Non-uniform tan mesh for grids. More dense at low abs values of the points, while less dense for higher values |\n        " .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.Mesh/spacing> rdfs:domain <https://fairmat-nfdi.github.io/nomad-simulations/rdf/section/nomad_simulations.schema_packages.numerical_settings.Mesh> .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.Mesh/spacing> rdfs:label "spacing" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.Mesh/spacing> rdfs:range xsd:string .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.Mesh/spacing> nomad:enumValue "Equidistant" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.Mesh/spacing> nomad:enumValue "Logarithmic" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.Mesh/spacing> nomad:enumValue "Tan" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.Mesh/spacing> nomad:propertyKind "quantity" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.Mesh/spacing> nomad:shape "['dimensionality']"^^xsd:string .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.Mesh/weights> rdf:type owl:DatatypeProperty .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.Mesh/weights> rdfs:comment "\n        Weight of each point. A value smaller than 1, typically indicates a symmetry operation that was\n        applied to the mesh. This quantity is equivalent to `multiplicities`:\n\n            weights = multiplicities / n_points\n        " .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.Mesh/weights> rdfs:domain <https://fairmat-nfdi.github.io/nomad-simulations/rdf/section/nomad_simulations.schema_packages.numerical_settings.Mesh> .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.Mesh/weights> rdfs:label "weights" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.Mesh/weights> rdfs:range xsd:double .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.Mesh/weights> nomad:propertyKind "quantity" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.Mesh/weights> nomad:shape "['n_points']"^^xsd:string .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.MultireferencePTSettings/contraction_type> rdf:type owl:DatatypeProperty .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.MultireferencePTSettings/contraction_type> rdfs:comment "\n        Contraction flavour used for the perturbative correction.\n          • strongly_contracted : strongly contracted NEVPT / CASPT variants\n          • partially_contracted: partially contracted NEVPT / CASPT variants\n          • internally_contracted: generic internal contraction (e.g., MRMP)\n          • uncontracted: no contraction of perturber space\n        " .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.MultireferencePTSettings/contraction_type> rdfs:domain <https://fairmat-nfdi.github.io/nomad-simulations/rdf/section/nomad_simulations.schema_packages.numerical_settings.MultireferencePTSettings> .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.MultireferencePTSettings/contraction_type> rdfs:label "contraction_type" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.MultireferencePTSettings/contraction_type> rdfs:range xsd:string .
