<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.model_method.GW/type> nomad:enumValue "ev-scGW" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.model_method.GW/type> nomad:enumValue "ev-scGW0" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.model_method.GW/type> nomad:enumValue "qp-scGW" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.model_method.GW/type> nomad:enumValue "qp-scGW0" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.model_method.GW/type> nomad:enumValue "scG0W" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.model_method.GW/type> nomad:enumValue "scGW" .
