<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.workflow.molecular_dynamics.ShearParameters/shear_rate> nomad:shape "[3, 3]"^^xsd:string .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.workflow.molecular_dynamics.ShearParameters/shear_rate> nomad:unit "'ps^-1'"^^xsd:string .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.workflow.molecular_dynamics.ShearParameters/shear_type> rdf:type owl:DatatypeProperty .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.workflow.molecular_dynamics.ShearParameters/shear_type> rdfs:comment "\n        The name of the method used to implement the effect of shear flow within the simulation.\n\n        Allowed values are:\n\n        | Shear Method          | Description                               |\n\n        | ---------------------- | ----------------------------------------- |\n\n        | `\"\"`                   | No thermostat               |\n\n        | `\"lees_edwards\"`          | A.W. Lees and S.F. Edwards,\n        [J. Phys. C **5** (1972) 1921](https://doi.org/10.1088/0022-3719/5/15/006)|\n\n        | `\"trozzi_ciccotti\"`          | A.W. Lees and S.F. Edwards,\n        [Phys. Rev. A **29** (1984) 916](https://doi.org/10.1103/PhysRevA.29.916)|\n\n        | `\"ashurst_hoover\"`          | W. T. Ashurst and W. G. Hoover,\n        [Phys. Rev. A **11** (1975) 658](https://doi.org/10.1103/PhysRevA.11.658)|\n        " .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.workflow.molecular_dynamics.ShearParameters/shear_type> rdfs:domain <https://fairmat-nfdi.github.io/nomad-simulations/rdf/section/nomad_simulations.schema_packages.workflow.molecular_dynamics.ShearParameters> .
