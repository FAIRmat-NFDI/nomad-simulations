<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.IntegralDecomposition/approximated_term> nomad:enumValue "cc" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.IntegralDecomposition/approximated_term> nomad:enumValue "coulomb" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.IntegralDecomposition/approximated_term> nomad:enumValue "exchange" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.IntegralDecomposition/approximated_term> nomad:enumValue "explicit_correlation" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.IntegralDecomposition/approximated_term> nomad:enumValue "jk" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.IntegralDecomposition/approximated_term> nomad:enumValue "mp2" .
