<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.atoms_state.HubbardInteractions/u_effective> rdfs:domain <https://fairmat-nfdi.github.io/nomad-simulations/rdf/section/nomad_simulations.schema_packages.atoms_state.HubbardInteractions> .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.atoms_state.HubbardInteractions/u_effective> rdfs:label "u_effective" .
