<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.NumericalSettings/name> rdf:type owl:DatatypeProperty .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.NumericalSettings/name> rdfs:comment "\n        Name of the numerical settings section. This is typically used for easy identification of\n        the `NumericalSettings` section within a `ModelMethod`. Possible values: \"KMesh\",\n        \"FrequencyMesh\", \"TimeMesh\", \"SelfConsistency\", \"BasisSet\".\n        " .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.NumericalSettings/name> rdfs:domain <https://fairmat-nfdi.github.io/nomad-simulations/rdf/section/nomad_simulations.schema_packages.numerical_settings.NumericalSettings> .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.NumericalSettings/name> rdfs:label "name" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.NumericalSettings/name> rdfs:range xsd:string .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.NumericalSettings/name> nomad:propertyKind "quantity" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.PPCutoff/cutoff_kind> rdf:type owl:DatatypeProperty .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.PPCutoff/cutoff_kind> rdfs:comment "\n        Identifies which physical expansion this cutoff controls. Plane-wave DFT codes\n        use different cutoffs for the wavefunction basis, charge density grid, PAW\n        augmentation charges, and response functions (e.g., for GW calculations). This\n        field disambiguates which expansion the cutoff value applies to.\n        " .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.PPCutoff/cutoff_kind> rdfs:domain <https://fairmat-nfdi.github.io/nomad-simulations/rdf/section/nomad_simulations.schema_packages.numerical_settings.PPCutoff> .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.PPCutoff/cutoff_kind> rdfs:label "cutoff_kind" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.PPCutoff/cutoff_kind> rdfs:range xsd:string .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.PPCutoff/cutoff_kind> nomad:enumValue "augmentation" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.PPCutoff/cutoff_kind> nomad:enumValue "charge_density" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.PPCutoff/cutoff_kind> nomad:enumValue "response" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.PPCutoff/cutoff_kind> nomad:enumValue "unavailable" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.PPCutoff/cutoff_kind> nomad:enumValue "wavefunction" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.PPCutoff/cutoff_kind> nomad:propertyKind "quantity" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.PPCutoff/cutoff_role> rdf:type owl:DatatypeProperty .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.PPCutoff/cutoff_role> rdfs:comment "\n        Pseudopotential files may provide more than one cutoff recommendation.\n        This field captures the recommendation context for the cutoff value: whether it\n        represents a single simulation package recommendation, bounds in a recommended range (min/max),\n        or a precision tier from a standard library.\n\n        The precision tiers follow the SSSP (Standard Solid-State Pseudopotentials)\n        protocol nomenclature: `'fast'` for testing and preliminary calculations,\n        `'balanced'` for high-throughput screening and most practical applications,\n        and `'stringent'` for production calculations requiring maximum precision\n        (Beal et al., arXiv:2504.03962, 2025).\n        " .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.PPCutoff/cutoff_role> rdfs:domain <https://fairmat-nfdi.github.io/nomad-simulations/rdf/section/nomad_simulations.schema_packages.numerical_settings.PPCutoff> .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.PPCutoff/cutoff_role> rdfs:label "cutoff_role" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.PPCutoff/cutoff_role> rdfs:range xsd:string .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.PPCutoff/cutoff_role> nomad:enumValue "balanced" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.PPCutoff/cutoff_role> nomad:enumValue "fast" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.PPCutoff/cutoff_role> nomad:enumValue "recommended" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.PPCutoff/cutoff_role> nomad:enumValue "recommended_max" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.PPCutoff/cutoff_role> nomad:enumValue "recommended_min" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.PPCutoff/cutoff_role> nomad:enumValue "stringent" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.PPCutoff/cutoff_role> nomad:propertyKind "quantity" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.PPCutoff/value> rdf:type owl:DatatypeProperty .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.PPCutoff/value> rdfs:comment "\n        The cutoff energy.\n        " .
