<https://fairmat-nfdi.github.io/nomad-simulations/rdf/section/nomad_simulations.schema_packages.properties.greens_function.QuasiparticleWeight> nomad:definesProperty <https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.properties.greens_function.QuasiparticleWeight/entity_ref> .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/section/nomad_simulations.schema_packages.properties.greens_function.QuasiparticleWeight> nomad:definesProperty <https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.properties.greens_function.QuasiparticleWeight/n_atoms> .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/section/nomad_simulations.schema_packages.properties.greens_function.QuasiparticleWeight> nomad:definesProperty <https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.properties.greens_function.QuasiparticleWeight/n_correlated_orbitals> .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/section/nomad_simulations.schema_packages.properties.greens_function.QuasiparticleWeight> nomad:definesProperty <https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.properties.greens_function.QuasiparticleWeight/spin_channel> .
