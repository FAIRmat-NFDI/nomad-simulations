<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.atoms_state.HubbardInteractions/u_effective> nomad:propertyKind "quantity" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.atoms_state.HubbardInteractions/u_effective> nomad:unit "'joule'"^^xsd:string .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.atoms_state.HubbardInteractions/u_interaction> rdf:type owl:DatatypeProperty .
