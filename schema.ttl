<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.workflow.molecular_dynamics.BarostatParameters/barostat_type> nomad:enumValue "nose_hoover" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.workflow.molecular_dynamics.BarostatParameters/barostat_type> nomad:enumValue "parrinello_rahman" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.workflow.molecular_dynamics.BarostatParameters/barostat_type> nomad:enumValue "stochastic_cell_rescaling" .
