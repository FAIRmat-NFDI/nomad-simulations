<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.properties.greens_function.QuasiparticleWeight/system_correlation_strengths> rdf:type owl:DatatypeProperty .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.properties.greens_function.QuasiparticleWeight/system_correlation_strengths> rdfs:comment "\n        String used to identify the type of system based on the strength of the electron-electron interactions.\n\n        | `type` | Description |\n        | ------ | ------ |\n        | 'non-correlated metal' | All `value` are above 0.7. Renormalization effects are negligible. |\n        | 'strongly-correlated metal' | All `value` are below 0.4 and above 0. Renormalization effects are important. |\n        | 'OSMI' | Orbital-selective Mott insulator: some orbitals have a zero `value` while others a finite one. |\n        | 'Mott insulator' | All `value` are 0.0. Mott insulator state. |\n        " .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.properties.greens_function.QuasiparticleWeight/system_correlation_strengths> rdfs:domain <https://fairmat-nfdi.github.io/nomad-simulations/rdf/section/nomad_simulations.schema_packages.properties.greens_function.QuasiparticleWeight> .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.properties.greens_function.QuasiparticleWeight/system_correlation_strengths> rdfs:label "system_correlation_strengths" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.properties.greens_function.QuasiparticleWeight/system_correlation_strengths> rdfs:range xsd:string .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.properties.greens_function.QuasiparticleWeight/system_correlation_strengths> nomad:enumValue "Mott insulator" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.properties.greens_function.QuasiparticleWeight/system_correlation_strengths> nomad:enumValue "OSMI" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.properties.greens_function.QuasiparticleWeight/system_correlation_strengths> nomad:enumValue "non-correlated metal" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.properties.greens_function.QuasiparticleWeight/system_correlation_strengths> nomad:enumValue "strongly-correlated metal" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.properties.greens_function.QuasiparticleWeight/system_correlation_strengths> nomad:propertyKind "quantity" .
