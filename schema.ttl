<https://fairmat-nfdi.github.io/nomad-simulations/rdf/section/nomad_simulations.schema_packages.workflow.general.WorkflowConvergenceTarget> nomad:pythonClass "nomad_simulations.schema_packages.workflow.general.WorkflowConvergenceTarget" .
