<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.KMesh/center> rdfs:range xsd:string .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.KMesh/center> nomad:enumValue "Gamma-centered" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.KMesh/center> nomad:enumValue "Gamma-offcenter" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.KMesh/center> nomad:enumValue "Monkhorst-Pack" .
