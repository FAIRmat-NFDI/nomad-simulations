<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.properties.thermodynamics.ChemicalPotential/particle_number> rdfs:comment "\n        Number of particles (or particle density) for which the chemical potential applies.\n        Can represent electron number, atom number, or other relevant particle count.\n        " .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.properties.thermodynamics.ChemicalPotential/particle_number> rdfs:domain <https://fairmat-nfdi.github.io/nomad-simulations/rdf/section/nomad_simulations.schema_packages.properties.thermodynamics.ChemicalPotential> .
