<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.properties.greens_function.BaseGreensFunction/entity_ref> nomad:propertyKind "quantity" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.properties.greens_function.BaseGreensFunction/local_model_type> rdf:type owl:DatatypeProperty .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.properties.greens_function.BaseGreensFunction/local_model_type> rdfs:comment "\n        Type of Green's function calculated from the mapping of the local Hubbard-Kanamori model\n        into the Anderson impurity model.\n\n        The `impurity` Green's function describe the electronic correlations for the impurity, and it\n        is a local function. The `lattice` Green's function includes the coupling to the lattice\n        and hence it is a non-local function. In DMFT, the `lattice` term is approximated to be the\n        `impurity` one, so that these simulations are converged if both types of the local\n        part of the `lattice` Green's function coincides with the `impurity` Green's function.\n        " .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.properties.greens_function.BaseGreensFunction/local_model_type> rdfs:domain <https://fairmat-nfdi.github.io/nomad-simulations/rdf/section/nomad_simulations.schema_packages.properties.greens_function.BaseGreensFunction> .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.properties.greens_function.BaseGreensFunction/local_model_type> rdfs:label "local_model_type" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.properties.greens_function.BaseGreensFunction/local_model_type> rdfs:range xsd:string .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.properties.greens_function.BaseGreensFunction/local_model_type> nomad:enumValue "impurity" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.properties.greens_function.BaseGreensFunction/local_model_type> nomad:enumValue "lattice" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.properties.greens_function.BaseGreensFunction/local_model_type> nomad:propertyKind "quantity" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.properties.greens_function.BaseGreensFunction/n_atoms> rdf:type owl:DatatypeProperty .
