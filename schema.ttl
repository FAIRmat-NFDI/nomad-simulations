<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.IntegralDecomposition/approximation_type> nomad:enumValue "CD" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.IntegralDecomposition/approximation_type> nomad:enumValue "CD_F12" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.IntegralDecomposition/approximation_type> nomad:enumValue "RIJ" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.IntegralDecomposition/approximation_type> nomad:enumValue "RIJCOSX" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.IntegralDecomposition/approximation_type> nomad:enumValue "RIJK" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.IntegralDecomposition/approximation_type> nomad:enumValue "SENEX" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.IntegralDecomposition/approximation_type> nomad:propertyKind "quantity" .
