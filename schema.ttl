<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.workflow.molecular_dynamics.BarostatParameters/pressure_profile> rdf:type owl:DatatypeProperty .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.workflow.molecular_dynamics.BarostatParameters/pressure_profile> rdfs:comment "\n        Type of pressure control procedure. Can be \"constant\" (no annealing), \"linear\", or \"exponential\".\n        If linear, \"pressure_update_delta\" specifies the corresponding update parameter.\n        If exponential, \"pressure_update_factor\" specifies the corresponding update parameter.\n        " .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.workflow.molecular_dynamics.BarostatParameters/pressure_profile> rdfs:domain <https://fairmat-nfdi.github.io/nomad-simulations/rdf/section/nomad_simulations.schema_packages.workflow.molecular_dynamics.BarostatParameters> .
