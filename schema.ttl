<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.model_system.ModelSystem/branch_label> rdfs:domain <https://fairmat-nfdi.github.io/nomad-simulations/rdf/section/nomad_simulations.schema_packages.model_system.ModelSystem> .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.model_system.ModelSystem/branch_label> rdfs:label "branch_label" .
