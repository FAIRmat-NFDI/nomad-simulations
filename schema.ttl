<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.Mesh/multiplicities> rdf:type owl:DatatypeProperty .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.Mesh/multiplicities> rdfs:comment "\n        The amount of times the same point reappears. A value larger than 1, typically indicates\n        a symmetry operation that was applied to the `Mesh`. This quantity is equivalent to `weights`:\n\n            multiplicities = n_points * weights\n        " .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.Mesh/multiplicities> rdfs:domain <https://fairmat-nfdi.github.io/nomad-simulations/rdf/section/nomad_simulations.schema_packages.numerical_settings.Mesh> .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.Mesh/multiplicities> rdfs:label "multiplicities" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.Mesh/multiplicities> rdfs:range xsd:double .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.Mesh/multiplicities> nomad:propertyKind "quantity" .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.Mesh/multiplicities> nomad:shape "['n_points']"^^xsd:string .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.Mesh/n_points> rdf:type owl:DatatypeProperty .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.Mesh/n_points> rdfs:comment "\n        Number of points in the mesh.\n        " .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.numerical_settings.Mesh/n_points> rdfs:domain <https://fairmat-nfdi.github.io/nomad-simulations/rdf/section/nomad_simulations.schema_packages.numerical_settings.Mesh> .
