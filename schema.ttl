<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.properties.molecular_orbitals.MolecularOrbitals/mo_energies> nomad:shape "['n_mo']"^^xsd:string .
<https://fairmat-nfdi.github.io/nomad-simulations/rdf/quantity/nomad_simulations.schema_packages.properties.molecular_orbitals.MolecularOrbitals/mo_energies> nomad:unit "'electron_volt'"^^xsd:string .
